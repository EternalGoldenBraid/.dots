#!/usr/bin/env bash

set -euo pipefail

STATE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/waybar"
STATE_FILE="$STATE_DIR/handy-status.env"
DB_PATH="${XDG_DATA_HOME:-$HOME/.local/share}/com.pais.handy/history.db"
SIGNAL=11

mkdir -p "$STATE_DIR"

load_state() {
    if [[ -f "$STATE_FILE" ]]; then
        # shellcheck disable=SC1090
        source "$STATE_FILE"
    else
        STATUS="idle"
        UPDATED_AT=0
    fi
}

save_state() {
    local status="$1"
    printf 'STATUS=%q\nUPDATED_AT=%q\n' "$status" "$(date +%s)" > "$STATE_FILE"
}

signal_waybar() {
    pkill -RTMIN+"$SIGNAL" waybar 2>/dev/null || true
}

watch_for_completion() {
    local previous_mtime="$1"
    local attempts=60
    local current_mtime=0

    for ((i = 0; i < attempts; i++)); do
        sleep 0.5
        current_mtime="$(stat -c %Y "$DB_PATH" 2>/dev/null || echo 0)"
        if [[ "$current_mtime" -gt "$previous_mtime" ]]; then
            save_state "idle"
            signal_waybar
            exit 0
        fi
    done

    save_state "idle"
    signal_waybar
}

# --- Main toggle logic ---
if [[ "${1:-}" == "--watch" ]]; then
    watch_for_completion "${2:-0}"
    exit 0
fi

load_state

if [[ "${STATUS:-idle}" == "recording" ]]; then
    previous_mtime="$(stat -c %Y "$DB_PATH" 2>/dev/null || echo 0)"
    save_state "transcribing"
    signal_waybar

    if handy --toggle-transcription; then
        nohup "$0" --watch "$previous_mtime" >/dev/null 2>&1 &
    else
        save_state "recording"
        signal_waybar
        exit 1
    fi
else
    save_state "recording"
    signal_waybar
    if ! handy --toggle-transcription; then
        save_state "idle"
        signal_waybar
        exit 1
    fi
fi
